# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/arogyaai?retryWrites=true&w=majority

# Redis (for caching, queues, and locks)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_ACCESS_SECRET=your_super_secret_access_key_min_64_chars_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP Security (HMAC pepper for defense-in-depth hashing)
OTP_PEPPER=your_otp_pepper_secret_key_change_this_in_production

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=ArogyaAI <noreply@arogyaai.health>

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (payment processing)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Cookie Security
COOKIE_SECRET=your_cookie_secret_key_here

# Voice Features (STT/TTS providers)
VOICE_STT_PROVIDER=google_cloud_speech
VOICE_TTS_PROVIDER=google_cloud_tts
